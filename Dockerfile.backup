# syntax=docker/dockerfile:1.7

FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates gnupg rclone \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /ops

COPY deploy/backup_sqlite.py /ops/backup_sqlite.py
COPY deploy/restore_sqlite_backup.py /ops/restore_sqlite_backup.py

CMD ["python", "/ops/backup_sqlite.py", "--loop"]
