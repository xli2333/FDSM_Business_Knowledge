# Copy this file to .env.docker before running docker compose.
# For build-time interpolation, run:
# docker compose --env-file .env.docker up -d --build

APP_ENV=production
APP_PORT=8080
SITE_BASE_URL=http://127.0.0.1:8080
ALLOWED_ORIGINS=http://127.0.0.1:8080

# Runtime data is mounted at /data inside containers.
FDSM_DATA_DIR=/data

# Database runtime. Default cloud bootstrap stays on SQLite; DATABASE_URL is reserved for PostgreSQL migration.
DATABASE_BACKEND=sqlite
DATABASE_URL=
DB_WRITE_RETRY_ATTEMPTS=5
DB_WRITE_RETRY_BASE_DELAY_SECONDS=0.05
DB_SLOW_QUERY_MS=750
DB_OBSERVABILITY_ENABLED=1
HOME_FEED_CACHE_TTL_SECONDS=30
METRICS_ENABLED=1
METRICS_TOKEN=
REQUEST_LOG_JSON_ENABLED=1
SENTRY_REQUIRED=0
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
MEDIA_AUDIO_UPLOAD_MAX_BYTES=536870912
MEDIA_VIDEO_UPLOAD_MAX_BYTES=2147483648
MEDIA_TEXT_UPLOAD_MAX_BYTES=20971520
MEDIA_IMAGE_UPLOAD_MAX_BYTES=20971520

# Keep preview/debug auth disabled in production.
DEV_AUTH_ENABLED=0
VITE_ENABLE_DEBUG_AUTH=0

# Production identity. Keep CAS disabled until the school CAS service URL and whitelist are ready.
AUTH_BACKEND=auto
CAS_ENABLED=0
CAS_SERVER_URL=
CAS_SERVICE_BASE_URL=
CAS_SERVICE_URL=
CAS_VALIDATE_TIMEOUT_SECONDS=8
CAS_SESSION_TTL_SECONDS=28800
CAS_SESSION_RETENTION_DAYS=30
CAS_ADMIN_EMPLOYEE_NUMBERS=
CAS_ADMIN_USERNAMES=

# Legacy backend compatibility only. Frontend no longer consumes Supabase env.
ALLOW_LEGACY_SUPABASE_AUTH=0
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Gemini keys must be set on the cloud host if AI features are enabled.
GOOGLE_API_KEY=
GEMINI_API_KEYS=
GEMINI_CHAT_MODEL=gemini-3.0-flash
GEMINI_FLASH_MODEL=gemini-3.0-flash

# Crawler/search/runtime tuning.
RAG_SEARCH_PROVIDER=local_chunk
RAG_ENABLE_INLINE_INGESTION=1
RAG_CHUNK_EMBEDDINGS_ENABLED=1

# Redis-backed async task queue.
REDIS_PASSWORD=fdsm-local-redis-pass
REDIS_MAXMEMORY=512mb
ASYNC_TASKS_ENABLED=1
ASYNC_TASK_QUEUE_KEY=fdsm:async-tasks
ASYNC_TASK_DEAD_LETTER_QUEUE_KEY=fdsm:async-tasks:dead-letter

# Container capacity guardrails.
GUNICORN_WORKERS=3
GUNICORN_PRELOAD=0
GUNICORN_WORKER_CONNECTIONS=1000
GUNICORN_TIMEOUT=180
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEP_ALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
BACKEND_WEB_CPUS=2.0
BACKEND_WEB_MEMORY=2g
BACKEND_WEB_RESERVATION_CPUS=0.5
BACKEND_WEB_RESERVATION_MEMORY=512m
BACKEND_WORKER_CPUS=1.0
BACKEND_WORKER_MEMORY=1g
BACKEND_WORKER_RESERVATION_CPUS=0.25
BACKEND_WORKER_RESERVATION_MEMORY=512m
HOUSEKEEPING_CPUS=0.25
HOUSEKEEPING_MEMORY=256m
HOUSEKEEPING_RESERVATION_CPUS=0.05
HOUSEKEEPING_RESERVATION_MEMORY=128m
HOUSEKEEPING_INTERVAL_SECONDS=3600
HOUSEKEEPING_HEARTBEAT_PATH=/tmp/fdsm-housekeeping.ok
HOUSEKEEPING_HEALTH_MAX_AGE_SECONDS=7200
FRONTEND_CPUS=1.0
FRONTEND_MEMORY=512m
FRONTEND_RESERVATION_CPUS=0.1
FRONTEND_RESERVATION_MEMORY=128m
REDIS_CPUS=0.5
REDIS_MEMORY=768m
REDIS_RESERVATION_CPUS=0.1
REDIS_RESERVATION_MEMORY=256m
BACKUP_CPUS=0.5
BACKUP_MEMORY=512m
BACKUP_RESERVATION_CPUS=0.1
BACKUP_RESERVATION_MEMORY=128m
LOG_MAX_SIZE=20m
LOG_MAX_FILE=5

# Backup container.
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
BACKUP_COMPRESS=1
BACKUP_ENCRYPTION_REQUIRED=0
BACKUP_ENCRYPTION_RECIPIENT=
BACKUP_OFFSITE_REQUIRED=0
BACKUP_OFFSITE_TARGET=
BACKUP_OFFSITE_COMMAND=rclone
